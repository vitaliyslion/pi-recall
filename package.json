{
  "name": "pi-recall",
  "version": "0.1.0",
  "description": "Pi extension: capture full bash output, index it (Orama BM25), and show the model a compact recall stub — reversible compaction.",
  "homepage": "https://github.com/vitaliyslion/pi-recall#readme",
  "bugs": {
    "url": "https://github.com/vitaliyslion/pi-recall/issues"
  },
  "license": "MIT",
  "author": "Vitalii Pedchenko <vitaliyslion@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitaliyslion/pi-recall.git"
  },
  "files": [
    "index.ts",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "check": "tsgo --noEmit -p tsconfig.json",
    "check:test": "tsgo --noEmit -p tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@orama/plugin-data-persistence": "^3.1.18",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@types/node": "^22.19.0",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1",
    "oxfmt": "^0.55.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
